{
    "name": "yellow-three/omnipay-iyzico",
    "description": "Iyzico gateway for Omnipay v3 payment processing library",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "iyzico",
        "payment",
        "gateway",
        "omnipay",
        "sanal pos"
    ],
    "autoload": {
        "psr-4": {
            "Omnipay\\Iyzico\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Omnipay\\Iyzico\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1",
        "omnipay/common": "^3",
        "iyzico/iyzipay-php": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "php-http/guzzle7-adapter": "^1.1"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-text"
    }
}
